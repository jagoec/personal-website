---
title: Books
layout: layout.njk
---

{{ "# Books I've Read" | markdown | safe }}

<table>
<thead>
<tr>
<th>Title</th>
<th>Author</th>
<th>Month Read</th>
<th>Notes</th>
</tr>
</thead>
<tbody>
{%- for book in books -%}
<tr>
<td>{{ book.Title }}</td>
<td>{{ book.Author }}</td>
<td>{{ book.Finished }}</td>
<td>{{ book.Notes }}</td>
</tr>
{%- endfor -%}
</tbody>
</table>
